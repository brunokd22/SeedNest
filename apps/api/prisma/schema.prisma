generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  MANAGER
  CUSTOMER
  ADMIN
}

enum SeedlingSize {
  SMALL_POT
  BIG_POT
}

enum AvailabilityStatus {
  AVAILABLE
  OUT_OF_STOCK
  COMING_SOON
}

enum FulfillmentType {
  DELIVERY
  PICKUP
}

enum FulfillmentStatus {
  PENDING
  PROCESSING
  DISPATCHED
  DELIVERED
  READY_FOR_PICKUP
  COLLECTED
}

enum SaleMethod {
  ONLINE
  WALKIN
}

enum IssueType {
  REPLACEMENT_REQUEST
  QUERY
  COMPLAINT
  GENERAL_REQUEST
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum NotificationType {
  NEW_ISSUE
  NEW_COMMENT
  LOW_STOCK
  ORDER_UPDATE
}

// ─── Auth Models (Better Auth) ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          UserRole  @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  nurseries     Nursery[]
  orders        Order[]
  issues        Issue[]
  issueComments IssueComment[]
  notifications Notification[]
  careReminders CareReminder[]
  reviews       Review[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id           String    @id @default(cuid())
  userId       String
  accountId    String
  providerId   String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  password     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Business Models ──────────────────────────────────────────────────────────

model Nursery {
  id                String   @id @default(cuid())
  managerId         String
  name              String
  description       String?
  address           String
  latitude          Float?
  longitude         Float?
  coverImageUrl     String?
  operatingHours    String?
  lowStockThreshold Int      @default(5)
  careReminderDays  Int      @default(14)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  manager    User       @relation(fields: [managerId], references: [id])
  categories Category[]
  seedlings  Seedling[]
  orders     Order[]
  issues     Issue[]
}

model Category {
  id          String   @id @default(cuid())
  nurseryId   String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  nursery   Nursery    @relation(fields: [nurseryId], references: [id], onDelete: Cascade)
  seedlings Seedling[]
}

model Seedling {
  id                 String             @id @default(cuid())
  nurseryId          String
  categoryId         String?
  name               String
  description        String?
  size               SeedlingSize
  price              Float
  quantity           Int                @default(0)
  availabilityStatus AvailabilityStatus @default(AVAILABLE)
  photos             String[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  nursery    Nursery      @relation(fields: [nurseryId], references: [id], onDelete: Cascade)
  category   Category?    @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  issues     Issue[]
  reviews    Review[]
}

model Order {
  id                   String            @id @default(cuid())
  nurseryId            String
  customerId           String?
  guestName            String?
  fulfillmentType      FulfillmentType
  fulfillmentStatus    FulfillmentStatus @default(PENDING)
  deliveryAddress      String?
  deliveryLat          Float?
  deliveryLng          Float?
  saleMethod           SaleMethod
  stripePaymentIntentId String?          @unique
  totalAmount          Float
  receiptEmailSent     Boolean           @default(false)
  notes                String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  nursery       Nursery        @relation(fields: [nurseryId], references: [id])
  customer      User?          @relation(fields: [customerId], references: [id])
  items         OrderItem[]
  issues        Issue[]
  careReminders CareReminder[]
}

model OrderItem {
  id           String @id @default(cuid())
  orderId      String
  seedlingId   String
  seedlingName String
  seedlingSize String
  unitPrice    Float
  quantity     Int

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  seedling Seedling @relation(fields: [seedlingId], references: [id])
}

model Issue {
  id          String      @id @default(cuid())
  orderId     String?
  seedlingId  String?
  customerId  String
  nurseryId   String
  title       String
  description String
  type        IssueType
  status      IssueStatus @default(OPEN)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  order    Order?         @relation(fields: [orderId], references: [id])
  seedling Seedling?      @relation(fields: [seedlingId], references: [id])
  customer User           @relation(fields: [customerId], references: [id])
  nursery  Nursery        @relation(fields: [nurseryId], references: [id])
  comments IssueComment[]
}

model IssueComment {
  id        String   @id @default(cuid())
  issueId   String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issue  Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  relatedId String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CareReminder {
  id          String    @id @default(cuid())
  orderId     String
  customerId  String
  scheduledAt DateTime
  sentAt      DateTime?
  isSent      Boolean   @default(false)

  order    Order @relation(fields: [orderId], references: [id])
  customer User  @relation(fields: [customerId], references: [id])
}

model Review {
  id         String   @id @default(cuid())
  seedlingId String
  customerId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  seedling Seedling @relation(fields: [seedlingId], references: [id])
  customer User     @relation(fields: [customerId], references: [id])

  @@unique([seedlingId, customerId])
}
