{
  "expo": {
    "name": "SeedNest",
    "slug": "seednest",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "seednest",
    "userInterfaceStyle": "light",
    "sdkVersion": "52.0.0",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SeedNest needs your location to find nearby nurseries."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "SeedNest needs camera access to take seedling photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SeedNest needs photo library access to upload seedling images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.seednest.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2D6A4F"
      },
      "package": "com.seednest.app"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
